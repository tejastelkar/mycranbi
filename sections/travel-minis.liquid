<div class="travel-edit section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    
    <div class="travel-edit__grid {% if section.settings.image_position == 'right' %}travel-edit__grid--reverse{% endif %}">
      
      <!-- LIFESTYLE IMAGE -->
      <div class="travel-edit__media-wrapper">
        <div class="travel-edit__media">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'travel-edit__image' }}
          {%- else -%}
            <img src="{{ 'slide-2.png' | asset_url }}" alt="Travel Edit" class="travel-edit__image" loading="lazy">
          {%- endif -%}
        </div>
      </div>

      <!-- CONTENT & SHOPPING LIST -->
      <div class="travel-edit__content-wrapper">
        <div class="travel-edit__content-box" style="background-color: {{ section.settings.list_background_color }};">
          
          <div class="travel-edit__header">
            {%- if section.settings.title != blank -%}
              <h2 class="travel-edit__heading {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
            {%- endif -%}
            {%- if section.settings.subtitle != blank -%}
              <div class="travel-edit__subtitle">{{ section.settings.subtitle }}</div>
            {%- endif -%}
          </div>

          <div class="travel-edit__list">
            {%- if section.blocks.size > 0 -%}
              {%- for block in section.blocks -%}
                {%- assign product = block.settings.product -%}
                
                {%- if product != blank -%}
                  <!-- REAL PRODUCT BLOCK -->
                  <div class="travel-edit__product" {{ block.shopify_attributes }}>
                    <a href="{{ product.url }}" class="travel-edit__product-link">
                      <div class="travel-edit__product-image-wrapper">
                        {%- if product.featured_image != blank -%}
                          {{ product.featured_image | image_url: width: 120 | image_tag: loading: 'lazy', class: 'travel-edit__product-image' }}
                        {%- else -%}
                          <img src="{{ 'slide-1.png' | asset_url }}" alt="Travel Size" class="travel-edit__product-image" loading="lazy">
                        {%- endif -%}
                      </div>
                      <div class="travel-edit__product-info">
                        <h3 class="travel-edit__product-title">{{ product.title }}</h3>
                        <p class="travel-edit__product-purpose">{{ product.metafields.descriptors.subtitle.value | default: "Nourishing daily essential" }}</p>
                        <div class="travel-edit__product-price">
                          {% render 'price', product: product, price_class: '' %}
                        </div>
                      </div>
                    </a>
                    
                    <div class="travel-edit__product-action">
                      {%- if product.available -%}
                        <product-form class="product-form">
                          {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled>
                            <button
                              type="submit"
                              name="add"
                              class="travel-edit__add-icon"
                              aria-haspopup="dialog"
                              aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                              aria-live="polite"
                              data-sold-out-message="true"
                              {% if product.selected_or_first_available_variant.available == false %}
                                disabled
                              {% endif %}
                            >
                              <span class="visually-hidden">{{ 'products.product.add_to_cart' | t }}</span>
                              {% render 'icon-plus' %}
                              <div class="loading-overlay__spinner hidden">
                                <svg
                                  aria-hidden="true"
                                  focusable="false"
                                  class="spinner"
                                  viewBox="0 0 66 66"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                                </svg>
                              </div>
                            </button>
                          {%- endform -%}
                        </product-form>
                      {%- else -%}
                         <button class="travel-edit__add-icon" disabled>
                           <span class="visually-hidden">Sold Out</span>
                           {% render 'icon-unavailable' %}
                         </button>
                      {%- endif -%}
                    </div>
                  </div>
                  
                {%- else -%}
                  <!-- PLACEHOLDER BLOCK -->
                  {%- assign placeholder_images = "slide-1.png,slide-2.png,slide-3.png" | split: "," -%}
                  {%- assign mod_index = forloop.index0 | modulo: 3 -%}
                  {%- assign image_name = placeholder_images[mod_index] -%}
                  
                  <div class="travel-edit__product" {{ block.shopify_attributes }}>
                    <a href="#" class="travel-edit__product-link">
                      <div class="travel-edit__product-image-wrapper">
                        <img src="{{ image_name | asset_url }}" alt="Placeholder" class="travel-edit__product-image" loading="lazy">
                      </div>
                      <div class="travel-edit__product-info">
                        <h3 class="travel-edit__product-title">Ayurvedic Travel Mini</h3>
                        <p class="travel-edit__product-purpose">Restorative and deeply hydrating</p>
                        <div class="travel-edit__product-price">
                          <span class="price-item price-item--regular">{{ 150000 | money }}</span>
                        </div>
                      </div>
                    </a>
                    
                    <div class="travel-edit__product-action">
                      <button type="button" class="travel-edit__add-icon">
                        <span class="visually-hidden">Add to cart</span>
                        <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 1v12m-6-6h12"/></svg>
                      </button>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </div>

          {%- if section.settings.show_view_all and section.settings.collection != blank -%}
            <div class="travel-edit__footer">
              <a href="{{ section.settings.collection.url }}" class="link">
                {{ 'sections.featured_collection.view_all' | t }}
              </a>
            </div>
          {%- endif -%}

        </div>
      </div>
      
    </div>
  </div>
</div>

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .travel-edit__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  @media screen and (min-width: 990px) {
    .travel-edit__grid {
      flex-direction: row;
      gap: 0; /* Flush together */
    }
    
    .travel-edit__grid--reverse {
      flex-direction: row-reverse;
    }
    
    .travel-edit__media-wrapper {
      width: 50%;
    }

    .travel-edit__content-wrapper {
      width: 50%;
    }
  }

  .travel-edit__media {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
  }
  
  @media screen and (min-width: 990px) {
    .travel-edit__media {
      height: 0;
      padding-bottom: 125%; /* 4:5 aspect ratio */
    }
  }

  .travel-edit__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .travel-edit__content-box {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3rem;
    height: 100%;
  }
  
  @media screen and (min-width: 990px) {
    .travel-edit__content-box {
      padding: 6rem 8rem;
    }
  }

  .travel-edit__header {
    margin-bottom: 4rem;
  }

  .travel-edit__heading {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .travel-edit__subtitle {
    font-size: 1.6rem;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.6;
  }

  .travel-edit__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .travel-edit__product {
    display: flex;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .travel-edit__product-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex-grow: 1;
    transition: opacity 0.2s ease;
  }

  .travel-edit__product-link:hover {
    opacity: 0.7;
  }

  .travel-edit__product-image-wrapper {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    margin-right: 2rem;
    border-radius: 4px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.02);
  }

  .travel-edit__product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .travel-edit__product-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-right: 2rem;
  }

  .travel-edit__product-title {
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
    color: rgba(var(--color-foreground), 1);
  }

  .travel-edit__product-purpose {
    font-family: var(--font-body-family);
    font-size: 1.2rem;
    font-style: italic;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 0.8rem 0;
  }

  .travel-edit__product-price {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.6);
  }

  .travel-edit__product-action {
    flex-shrink: 0;
    padding-left: 1.5rem;
  }
  
  .travel-edit__add-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    background: transparent;
    color: rgba(var(--color-foreground), 0.8);
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .travel-edit__add-icon:hover {
    border-color: rgba(var(--color-foreground), 1);
    color: rgba(var(--color-foreground), 1);
    background: rgba(var(--color-foreground), 0.03);
  }
  
  .travel-edit__add-icon:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .travel-edit__add-icon .icon {
    width: 1.2rem;
    height: 1.2rem;
  }
  
  /* Loading spinner for Quick Add */
  .travel-edit__add-icon .loading-overlay__spinner {
    width: 1.2rem;
    height: 1.2rem;
  }
  
  .travel-edit__add-icon[aria-busy="true"] .icon-plus {
    display: none;
  }
  .travel-edit__add-icon[aria-busy="true"] .loading-overlay__spinner {
    display: block;
  }

  .travel-edit__footer {
    margin-top: 4rem;
  }
  
  .travel-edit__footer .link {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.4rem;
    color: rgba(var(--color-foreground), 0.75);
  }
</style>

{% schema %}
{
  "name": "Travel Minis",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Desktop image placement"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Rituals for every journey",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "default": "<p>Discover travel-friendly favourites for care on the go.</p>",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection for 'View All' link (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Enable \"View all\" link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Outer background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "list_background_color",
      "label": "List container background color",
      "default": "#FAF7F2"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Travel Minis",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
