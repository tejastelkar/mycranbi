<div class="brand-story section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="brand-story__header">
        <h2 class="brand-story__heading {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    <div class="brand-story__grid">
      {%- for block in section.blocks -%}
        <div class="brand-story__column" {{ block.shopify_attributes }}>
          <div class="brand-story__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'brand-story__image' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="brand-story__content">
            {%- if block.settings.title != blank -%}
              <h3 class="brand-story__column-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="brand-story__column-text rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .brand-story__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .brand-story__heading {
    margin: 0;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .brand-story__header {
      margin-bottom: 4rem;
    }
  }

  .brand-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 750px) {
    .brand-story__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .brand-story__column {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand-story__media {
    width: 100%;
    position: relative;
    padding-bottom: 66.66%; /* 3:2 aspect ratio */
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    background-color: #f4f4f4;
  }

  .brand-story__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .placeholder-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #f4f4f4;
  }

  .brand-story__column-title {
    margin: 0 0 1.5rem 0;
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
  }

  .brand-story__column-text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.8);
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "OUR STORY",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Story Column",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Column title",
          "label": "Subtitle"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Write a short paragraph explaining the core values, history, or ingredients of your brand.</p>",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "ROOTED IN AYURVEDA"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "A MULTI-SENSORIAL JOURNEY"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "FRESH. PURE. POTENT."
          }
        }
      ]
    }
  ]
}
{% endschema %}
