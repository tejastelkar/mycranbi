<div class="page-width" style="padding-top: 4rem; padding-bottom: 6rem;">
  <div style="text-align: center; margin-bottom: 3rem;">
    <h1 style="font-family: var(--font-heading-family); font-size: 3.5rem; margin-bottom: 1rem;">Your Wishlist</h1>
    <p style="color: #666; font-size: 1.5rem;">Save your favorite items here.</p>
  </div>
  
  <div id="wishlist-empty-state" style="display: none; text-align: center; padding: 4rem 2rem; background: #fafafa; border-radius: 8px;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: #ccc; margin-bottom: 1.5rem;">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <h2 style="font-family: var(--font-heading-family); font-size: 2rem; margin-bottom: 1rem; color: #333;">Your wishlist is empty</h2>
    <p style="color: #666; font-size: 1.4rem; margin-bottom: 2rem;">Looks like you haven't added anything to your wishlist yet.</p>
    <a href="{{ routes.all_products_collection_url }}" class="button" style="padding: 1rem 3rem; background: #000; color: #fff; text-decoration: none; text-transform: uppercase; letter-spacing: 1px; font-size: 1.3rem;">Continue Shopping</a>
  </div>

  <div id="wishlist-grid" style="display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 3rem;">
    <!-- Rendered via JS -->
  </div>
</div>

{% schema %}
{
  "name": "Wishlist Page",
  "settings": []
}
{% endschema %}
 
