<div class="custom-collection-slider">
  <div class="page-width">
    <div class="custom-collection-slider__track">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        {%- assign card_link = block.settings.link | default: collection.url -%}
        {%- assign card_title = block.settings.title | default: collection.title -%}
        {%- assign card_image = block.settings.image | default: collection.featured_image -%}
        
        <a {% if card_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ card_link }}"{% endif %} class="custom-collection-slider__card" {{ block.shopify_attributes }}>
          <div class="custom-collection-slider__image-wrapper">
            {%- if card_image != blank -%}
              <img src="{{ card_image | image_url: width: 600 }}" 
                   alt="{{ card_title | escape }}"
                   loading="lazy"
                   width="{{ card_image.width }}"
                   height="{{ card_image.height }}"
                   class="custom-collection-slider__image">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg custom-collection-slider__image' }}
            {%- endif -%}
            <div class="custom-collection-slider__overlay"></div>
          </div>
          <div class="custom-collection-slider__content">
            <h3 class="custom-collection-slider__title">
              {%- if card_title != blank -%}
                {{ card_title | escape }}
              {%- else -%}
                Collection
              {%- endif -%}
            </h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .custom-collection-slider {
    padding-top: 0;
    padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    background-color: transparent;
    width: 100%;
    margin-top: 0;
    position: relative;
  }

  .custom-collection-slider__track {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0;
  }

  .custom-collection-slider__track::-webkit-scrollbar {
    display: none;
  }

  .custom-collection-slider__card {
    flex: 1 1 0;
    min-width: 160px;
    position: relative;
    border-radius: 0;
    overflow: hidden;
    text-decoration: none;
    scroll-snap-align: start;
    aspect-ratio: 3 / 4;
    display: block;
    transition: transform 0.3s ease;
  }

  .custom-collection-slider__card:hover {
    transform: scale(1.02);
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .custom-collection-slider__card {
      flex: 0 0 44vw;
      min-width: 44vw;
    }
    .custom-collection-slider__track {
      gap: 4px;
    }
  }

  .custom-collection-slider__image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .custom-collection-slider__image,
  .custom-collection-slider__image-wrapper svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
    max-height: 100% !important;
    object-fit: cover;
    display: block;
  }

  .custom-collection-slider__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 40%, rgba(0,0,0,0.65) 100%);
    z-index: 1;
    transition: background 0.3s ease;
  }

  .custom-collection-slider__card:hover .custom-collection-slider__overlay {
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 20%, rgba(0,0,0,0.75) 100%);
  }

  .custom-collection-slider__content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    z-index: 2;
    padding: 16px;
  }

  .custom-collection-slider__title {
    color: #ffffff;
    font-size: 1rem;
    font-weight: 700;
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  @media screen and (min-width: 750px) {
    .custom-collection-slider__title {
      font-size: 1.1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Collection Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image",
          "info": "Optional. Overrides the collection's default image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Heading",
          "info": "Optional. Overrides the collection's default title."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override Link",
          "info": "Optional. Overrides the collection's default link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Slider",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "SKINCARE"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "HAIRCARE"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "SANDANYA COLLECTION"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "BRINGARAS COLLECTION"
          }
        }
      ]
    }
  ]
}
{% endschema %}
