{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .reviews-section {
    background-color: #FFFFFF;
    color: #4A3427;
  }

  .reviews-section__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .reviews-section__heading {
    margin: 0;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .reviews-grid {
    display: flex;
    flex-wrap: nowrap;
    padding-bottom: 2rem;
  }

  .review-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    border: 1px solid #E9DFD2;
    background-color: #FFFFFF;
    height: auto;
  }

  @media screen and (min-width: 750px) {
    .review-card {
      border: none;
      padding: 0 3rem;
      border-right: 1px solid #E9DFD2;
    }
    
    .review-card:last-child {
      border-right: none;
    }
  }

  .review-card__stars {
    color: #C9974D;
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .review-card__stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .review-card__text {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    line-height: 1.6;
    margin: 0 0 2rem 0;
    font-style: italic;
    color: #4A3427;
  }

  .review-card__author {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    margin: auto 0 0 0;
    color: #4A3427;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .review-card__product {
    font-size: 1.2rem;
    color: rgba(74, 52, 39, 0.7);
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
{%- endstyle -%}

<div class="reviews-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="reviews-section__header">
        <h2 class="reviews-section__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    <div class="swiper reviewsSwiper">
      <div class="swiper-wrapper reviews-grid">
        {%- for block in section.blocks -%}
          <div class="swiper-slide review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {%- endfor -%}
          </div>
          
          {%- if block.settings.review_text != blank -%}
            <p class="review-card__text">"{{ block.settings.review_text | escape }}"</p>
          {%- endif -%}
          
          {%- if block.settings.author != blank -%}
            <p class="review-card__author">{{ block.settings.author | escape }}</p>
          {%- endif -%}

          {%- if block.settings.product_name != blank -%}
            <p class="review-card__product">{{ block.settings.product_name | escape }}</p>
          {%- endif -%}
        </div>
      {%- else -%}
        <!-- Placeholder content if no blocks -->
        {%- for i in (1..3) -%}
          <div class="swiper-slide review-card">
            <div class="review-card__stars">
              {%- for j in (1..5) -%}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {%- endfor -%}
            </div>
            <p class="review-card__text">"A truly beautiful product. The texture and scent are wonderfully luxurious and it absorbs perfectly into the skin."</p>
            <p class="review-card__author">Verified Buyer</p>
            <p class="review-card__product">Radiance Serum</p>
          </div>
        {%- endfor -%}
      {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  function initReviewsSwiper() {
    const swiperContainer = document.querySelector('.reviewsSwiper');
    if (!swiperContainer) return;
    
    if (swiperContainer.swiper) {
      swiperContainer.swiper.destroy();
    }

    new Swiper('.reviewsSwiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      breakpoints: {
        750: {
          slidesPerView: 3,
          spaceBetween: 0,
        }
      }
    });
  }

  function bootReviewsSwiper() {
    if (typeof Swiper === 'undefined') {
      window.addEventListener('load', initReviewsSwiper, { once: true });
      return;
    }
    initReviewsSwiper();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootReviewsSwiper);
  } else {
    bootReviewsSwiper();
  }

  document.addEventListener('shopify:section:load', function(event) {
    if (event.target.querySelector('.reviewsSwiper')) {
      bootReviewsSwiper();
    }
  });
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Loved by our Community",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 20,
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "default": "This has completely transformed my daily ritual. The scent is grounding and the results are visible instantly.",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Aisha K.",
          "label": "Author name"
        },
        {
          "type": "text",
          "id": "product_name",
          "default": "Lumière Botanique Serum",
          "label": "Product name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
