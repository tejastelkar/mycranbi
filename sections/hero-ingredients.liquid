<div class="hero-ingredients section-{{ section.id }}-padding" style="background-color: #FFFFFF;">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="hero-ingredients__title-wrapper" style="margin-bottom: 3rem;">
        <h2 class="hero-ingredients__title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endif -%}

    <div class="hero-ingredients__scroller">
      <ul class="hero-ingredients__list" role="list">
        {%- for block in section.blocks -%}
          <li class="hero-ingredients__item center" {{ block.shopify_attributes }}>
            <div class="hero-ingredients__card">
              <div class="hero-ingredients__media-wrapper">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'hero-ingredients__image' }}
                {%- else -%}
                  {%- assign slide_idx = forloop.index | modulo: 4 -%}
                  {%- if slide_idx == 0 -%}{%- assign slide_idx = 4 -%}{%- endif -%}
                  {%- capture placeholder_image -%}slide-{{ slide_idx }}.png{%- endcapture -%}
                  <img src="{{ placeholder_image | asset_url }}" alt="Ingredient {{ forloop.index }}" class="hero-ingredients__image" loading="lazy">
                {%- endif -%}
              </div>
              <h3 class="hero-ingredients__name">{{ block.settings.title }}</h3>
              <div class="hero-ingredients__purpose rte">{{ block.settings.purpose }}</div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hero-ingredients__title-wrapper {
    text-align: center;
    margin-bottom: 5rem;
  }
  
  .hero-ingredients__title {
    margin-bottom: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-ingredients__subtitle {
    color: rgba(var(--color-foreground), 0.6);
    font-size: 1.6rem;
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }

  .hero-ingredients__scroller {
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    padding-bottom: 2rem;
  }
  
  .hero-ingredients__scroller::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  .hero-ingredients__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 3rem;
  }

  .hero-ingredients__item {
    scroll-snap-align: start;
    flex: 0 0 75%;
  }
  
  @media screen and (min-width: 750px) {
    .hero-ingredients__item {
      flex: 0 0 calc(33.333% - 2rem);
    }
  }

  @media screen and (min-width: 990px) {
    .hero-ingredients__item {
      flex: 0 0 calc(25% - 2.25rem);
    }
  }

  .hero-ingredients__card {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Borderless, pure container */
  .hero-ingredients__media-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-ingredients__image {
    width: 100%;
    height: 100%;
    object-fit: contain; /* allows transparent PNGs to sit beautifully without cropping */
  }

  .hero-ingredients__media-wrapper .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: rgba(var(--color-foreground), 0.05);
  }

  .hero-ingredients__name {
    margin: 0 0 1rem 0;
    font-size: 2.6rem;
    letter-spacing: 0.02em;
  }

  .hero-ingredients__purpose {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    max-width: 90%;
    margin: 0 auto;
    font-weight: 300;
  }
</style>

{% schema %}
{
  "name": "Hero Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Nature's Finest",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Discover the rooted Ayurvedic ingredients inside every Cranbi bottle.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (Transparent PNG recommended)"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Ingredient Name",
          "label": "Name"
        },
        {
          "type": "richtext",
          "id": "purpose",
          "default": "<p>One-line purpose of this ingredient.</p>",
          "label": "Purpose"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Ingredients",
      "blocks": [
        {
          "type": "ingredient"
        },
        {
          "type": "ingredient"
        },
        {
          "type": "ingredient"
        },
        {
          "type": "ingredient"
        }
      ]
    }
  ]
}
{% endschema %}
