<div class="custom-hero-section">
  <div class="custom-hero-slider" id="CustomHeroSlider-{{ section.id }}">
    <div class="custom-hero-slides">
      {%- for block in section.blocks -%}
        <div class="custom-hero-slide" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="custom-hero__image-wrapper">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 2000 }}" 
                   alt="{{ block.settings.image.alt | escape }}" 
                   class="custom-hero__image desktop-only"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                   width="{{ block.settings.image.width }}"
                   height="{{ block.settings.image.height }}">
            {%- else -%}
              <img src="{{ 'hero-banner.png' | asset_url }}" alt="Hero Placeholder" class="custom-hero__image desktop-only" loading="lazy">
            {%- endif -%}

            {%- if block.settings.mobile_image != blank -%}
              <img src="{{ block.settings.mobile_image | image_url: width: 1000 }}" 
                   alt="{{ block.settings.mobile_image.alt | escape }}" 
                   class="custom-hero__image mobile-only"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                   width="{{ block.settings.mobile_image.width }}"
                   height="{{ block.settings.mobile_image.height }}">
            {%- else -%}
              <img src="{{ 'hero-banner.png' | asset_url }}" alt="Hero Placeholder" class="custom-hero__image mobile-only" loading="lazy">
            {%- endif -%}
          </div>

          <div class="custom-hero__content-wrapper page-width">
            {%- if block.settings.logo != blank -%}
              <div class="custom-hero__logo">
                <img src="{{ block.settings.logo | image_url: width: 150 }}" 
                     alt="Brand Logo" 
                     width="80" height="80">
              </div>
            {%- endif -%}

            {%- if block.settings.subheading != blank or block.settings.heading != blank or block.settings.description != blank or block.settings.stat_1_number != blank or block.settings.stat_2_number != blank or block.settings.button_label != blank -%}
              <div class="custom-hero__text-box">
                {%- if block.settings.subheading != blank -%}
                  <div class="custom-hero__subheading">{{ block.settings.subheading }}</div>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <h2 class="custom-hero__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="custom-hero__description">{{ block.settings.description }}</p>
                {%- endif -%}

                <div class="custom-hero__stats-grid">
                  {%- if block.settings.stat_1_number != blank -%}
                    <div class="custom-hero__stat">
                      <span class="custom-hero__stat-number">{{ block.settings.stat_1_number }}</span>
                      <span class="custom-hero__stat-text">{{ block.settings.stat_1_text }}</span>
                    </div>
                  {%- endif -%}
                  
                  {%- if block.settings.stat_2_number != blank -%}
                    <div class="custom-hero__stat">
                      <span class="custom-hero__stat-number">{{ block.settings.stat_2_number }}</span>
                      <span class="custom-hero__stat-text">{{ block.settings.stat_2_text }}</span>
                    </div>
                  {%- endif -%}
                </div>

                {%- if block.settings.button_label != blank -%}
                  <a href="{{ block.settings.button_link }}" class="button button--primary custom-hero__button">
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
    
    {%- if section.blocks.size > 1 -%}
      <div class="custom-hero-dots">
        {%- for block in section.blocks -%}
          <button class="custom-hero-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.custom-hero-section {
  position: relative;
  width: 100%;
  min-height: 50vh;
  background-color: #2D4C3A; /* Fallback Kama green */
}

.custom-hero-slider {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.custom-hero-slides {
  display: flex;
  width: 100%;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none;  /* IE and Edge */
  scroll-behavior: smooth;
}

.custom-hero-slides::-webkit-scrollbar {
  display: none; /* Chrome, Safari and Opera */
}

.custom-hero-slide {
  flex: 0 0 100%;
  width: 100%;
  position: relative;
  scroll-snap-align: start;
  min-height: 50vh;
  overflow: hidden;
}

.custom-hero__image-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.custom-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.desktop-only { display: block; }
.mobile-only { display: none; }

.custom-hero__content-wrapper {
  position: relative;
  z-index: 2;
  height: 100%;
  min-height: 50vh;
  display: flex;
  align-items: center;
  justify-content: flex-end; /* Right aligned text */
}

.custom-hero__logo {
  position: absolute;
  top: 40px;
  left: 40px;
}

.custom-hero__logo img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
}

.custom-hero__text-box {
  width: 100%;
  max-width: 480px;
  color: #fff; /* White text on dark background */
  padding: 40px 0;
}

.custom-hero__subheading {
  font-family: var(--font-body-family);
  font-size: 1.2rem;
  letter-spacing: 0.2rem;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.custom-hero__heading {
  font-family: var(--font-heading-family);
  font-size: 6rem;
  line-height: 1.1;
  font-weight: 400;
  margin: 0 0 1.5rem 0;
  color: #fff;
}

.custom-hero__description {
  font-family: var(--font-heading-family);
  font-size: 2.8rem;
  line-height: 1.2;
  font-weight: 400;
  margin: 0 0 3rem 0;
}

.custom-hero__stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-bottom: 4rem;
}

.custom-hero__stat {
  display: flex;
  flex-direction: column;
}

.custom-hero__stat-number {
  font-family: var(--font-heading-family);
  font-size: 5rem;
  line-height: 1;
  font-weight: 400;
  margin-bottom: 0.5rem;
}

.custom-hero__stat-text {
  font-family: var(--font-heading-family);
  font-size: 2rem;
  line-height: 1.2;
}

.custom-hero__button {
  margin-top: 1rem;
}

.custom-hero-dots {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12px;
  z-index: 10;
}

.custom-hero-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.6);
  cursor: pointer;
  padding: 0;
  transition: all 0.3s ease;
}

.custom-hero-dot.active {
  background-color: #fff;
  border-color: #fff;
  transform: scale(1.1);
}

@media screen and (max-width: 989px) {
  .custom-hero-section, .custom-hero-slide {
    display: flex;
    flex-direction: column;
    background-color: #2D4C3A;
  }

  .desktop-only { display: none; }
  .mobile-only { display: block; }
  
  .custom-hero__image-wrapper {
    position: relative;
    height: 60vh;
    min-height: 400px;
  }
  
  .custom-hero__content-wrapper {
    min-height: unset;
    padding-top: 0;
    justify-content: center;
    flex-direction: column;
  }
  
  .custom-hero__logo {
    position: relative;
    top: auto;
    left: auto;
    margin: -80px auto 20px auto;
    z-index: 10;
  }
  
  .custom-hero__text-box {
    background-color: #2D4C3A;
    padding: 40px 20px;
    text-align: center;
    max-width: 100%;
  }
  
  .custom-hero__heading {
    font-size: 4rem;
  }
  
  .custom-hero__description {
    font-size: 2.2rem;
  }
  
  .custom-hero__stat-number {
    font-size: 4rem;
  }
  
  .custom-hero-dots {
    bottom: unset;
    top: 55vh; /* Just below image on mobile before text */
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const sliders = document.querySelectorAll('.custom-hero-slider');
  
  sliders.forEach(slider => {
    const slidesContainer = slider.querySelector('.custom-hero-slides');
    const dots = slider.querySelectorAll('.custom-hero-dot');
    
    if(!slidesContainer || dots.length === 0) return;

    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        const index = parseInt(e.target.dataset.index);
        const slideWidth = slidesContainer.clientWidth;
        slidesContainer.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
      });
    });

    slidesContainer.addEventListener('scroll', () => {
      // Small timeout to allow scroll to settle and prevent excessive updates
      clearTimeout(slidesContainer.scrollTimeout);
      slidesContainer.scrollTimeout = setTimeout(() => {
        const index = Math.round(slidesContainer.scrollLeft / slidesContainer.clientWidth);
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      }, 50);
    });
  });
});
</script>

{% schema %}
{
  "name": "Custom Hero Slider",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Floating Logo"
        },
        {
          "type": "text",
          "id": "subheading",
          "default": "NEW",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "bringaras",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "Regenerating Haircare Ritual",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "stat_1_number",
          "default": "92%",
          "label": "Stat 1 Number"
        },
        {
          "type": "text",
          "id": "stat_1_text",
          "default": "Repaired fibre",
          "label": "Stat 1 Text"
        },
        {
          "type": "text",
          "id": "stat_2_number",
          "default": "84%",
          "label": "Stat 2 Number"
        },
        {
          "type": "text",
          "id": "stat_2_text",
          "default": "Stronger hair",
          "label": "Stat 2 Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "SHOP NOW",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Slider",
      "category": "Image",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
